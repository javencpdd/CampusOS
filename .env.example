# CampusOS local development environment

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
HOST_API_ENABLED=true
HOST_API_ADDR=127.0.0.1:18080

DATABASE_DSN=postgres://campusos:campusos_dev@localhost:5432/campusos?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=campusos
DB_NAME=campusos
DB_PASSWORD=campusos_dev
MIGRATIONS_DIR=migrations
POSTGRES_PORT=5432

REDIS_ENABLED=true
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_PORT=6379

NATS_URL=nats://localhost:4222
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222

PGADMIN_PORT=5050

JWT_SECRET=campusos-dev-secret-key-change-in-production
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=720h
JWT_ISSUER=campusos

# true: bcrypt password hash, recommended.
# false: plaintext password storage/login, local debugging only.
AUTH_PASSWORD_HASH_ENABLED=true

PLUGINS_DIR=examples/plugins
PLUGIN_DATA_DIR=.campusos/plugin-data

AI_ENABLED=false
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_TIMEOUT=30s
AI_MAX_REQUESTS_PER_MINUTE=60
AI_MAX_CONCURRENT=4
